{
  "name": "sigai",
  "description": "XAUUSD AI Core - SMC Scalping Bot with AI-Driven Code Mechanic",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "author": {
    "name": "muhadar2711-ctrl"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/muhadar2711-ctrl/Sigai.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "trading",
    "scalping",
    "smc",
    "ai",
    "xauusd",
    "forex",
    "bot"
  ],
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit && eslint src/ server/",
    "format": "prettier --write \"src/**/*.ts\" \"src/**/*.tsx\" \"server/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"src/**/*.tsx\" \"server/**/*.ts\" \"tests/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "test": "tsx tests/system.test.ts"
  },
  "dependencies": {
    "@google/genai": "^2.8.0",
    "@octokit/rest": "^22.0.1",
    "@supabase/supabase-js": "^2.108.2",
