# .env.example - Environment Variables Configuration

# SECURITY / AUTH
ADMIN_SECRET=your_secure_admin_password_here

# --------------------------
# MARKET DATA (TwelveData / Binance)
# --------------------------
TWELVEDATA_API_KEY=your_twelvedata_api_key_here
BINANCE_PUBLIC_KEY=optional_binance_pub_key
ALPHAVANTAGE_API_KEY=optional_alpha_key
POLYGON_API_KEY=optional_polygon_key

# --------------------------
# EXECUTION (MetaApi / Brokers)
# --------------------------
META_API_TOKEN=your_metaapi_token_here
META_API_ACCOUNT_ID=your_metaapi_account_id_here
EA_WEBHOOK_SECRET=your_secret_for_local_ea_webhook

# --------------------------
# NEWS & SENTIMENT (Twitter / Investing / ForexFactory)
# --------------------------
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# --------------------------
# NOTIFICATION (Telegram / Discord)
# --------------------------
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
DISCORD_WEBHOOK_URL=your_discord_webhook_url

# --------------------------
# AI & RAG (OpenAI / Gemini / Pinecone)
# --------------------------
OPENAI_API_KEY=your_openai_api_key
GEMINI_API_KEY=your_gemini_api_key
PINECONE_API_KEY=your_pinecone_api_key
COHERE_API_KEY=optional_cohere_key

# --------------------------
# CACHE & MONITORING (Redis / Sentry)
# --------------------------
REDIS_URL=redis://localhost:6379/1
SENTRY_DSN=your_sentry_dsn_here

# --------------------------
# INFRA / MISC
# --------------------------
PY_BACKEND_URL=http://127.0.0.1:8000
PORT=8000
ENVIRONMENT=development
