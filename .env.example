# Environment Variables for XAUUSD SMC AI System

# Security / Authorization
ADMIN_SECRET=your_secure_admin_password_here
WEBHOOK_SECRET_TOKEN=your_secure_webhook_token_here

# AI Provider Keys (at least one required)
GEMINI_API_KEY=
GEMINI_API_KEY_2=
XAI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
FREE_AI_API_KEY=
FREE_AI_BASE_URL=
FREE_AI_MODEL=gpt-3.5-turbo

# Data Feed & Filter
TWELVEDATA_API_KEY=xxxxxxxx            # Websocket Market Data (Saham, Forex, Crypto)
NEWS_API_KEY=xxxxxxxx                  # API Key dari NewsAPI (opsional)

# Notifikasi Telegram 
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...   # Token Bot Telegram dari BotFather
TELEGRAM_CHAT_ID=-100123...            # Chat ID tujuan signal

# Database Storage 
FIREBASE_PROJECT_ID=my-project         # Integrasi Firestore untuk menyimpan historis order
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
APP_TIMEZONE=Asia/Makassar
APP_URL=

# Auto-Trading (MetaApi)
META_API_TOKEN=
META_API_ACCOUNT_ID=
MT5_REGION_URL=https://mt-client-api-v1.new-york.agiliumtrade.ai

# Scanning Configuration
SCAN_START_HOUR=13
SCAN_END_HOUR=22

# Model Context Protocol (MCP) — Python Backend M on Railway
# This is the URL of your Python MCP server (backend M)
# All endpoints use /api/v1 prefix
MCP_SERVER_URL=https://your-mcp-server-url.up.railway.app

# Python Backend (legacy — use MCP_SERVER_URL instead)
# PY_BACKEND_URL is deprecated, use MCP_SERVER_URL
